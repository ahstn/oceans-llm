{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "gateway": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 1 },
        "image": { "$ref": "#/definitions/image" },
        "containerPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "configMountPath": { "type": "string", "minLength": 1 },
        "allowLiteralSecretsInConfig": { "type": "boolean" },
        "config": {
          "type": "object",
          "description": "Structured gateway.yaml content rendered into the ConfigMap."
        },
        "extraEnv": { "$ref": "#/definitions/envList" },
        "extraEnvFrom": { "type": "array" },
        "extraVolumes": { "type": "array" },
        "extraVolumeMounts": { "type": "array" },
        "podSecurityContext": { "type": "object" },
        "securityContext": { "type": "object" },
        "initSecurityContext": { "type": "object" },
        "migrationWaiter": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "oneOf": [
                { "type": "boolean" },
                { "type": "string", "enum": ["auto"] }
              ]
            },
            "intervalSeconds": { "type": "integer", "minimum": 1 },
            "timeoutSeconds": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "adminUi": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 1 },
        "image": { "$ref": "#/definitions/image" },
        "containerPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "extraEnv": { "$ref": "#/definitions/envList" },
        "extraEnvFrom": { "type": "array" },
        "extraVolumes": { "type": "array" },
        "extraVolumeMounts": { "type": "array" },
        "podSecurityContext": { "type": "object" },
        "securityContext": { "type": "object" }
      }
    },
    "database": {
      "type": "object",
      "required": ["mode"],
      "additionalProperties": true,
      "properties": {
        "mode": { "type": "string", "enum": ["external", "cloudnativepg"] },
        "external": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "existingSecret": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string" },
                "key": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        "cloudnativepg": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "clusterName": { "type": "string" },
            "instances": { "type": "integer", "minimum": 1 },
            "database": { "type": "string", "minLength": 1 },
            "owner": { "type": "string", "minLength": 1 },
            "existingCredentialsSecret": { "type": "string" },
            "storage": { "$ref": "#/definitions/storage" },
            "walStorage": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "enabled": { "type": "boolean" },
                "size": { "type": "string", "minLength": 1 },
                "storageClass": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "secrets": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "inline": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "existingSecret": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string" }
          }
        }
      }
    },
    "externalSecrets": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "apiVersion": { "type": "string", "minLength": 1 },
        "refreshInterval": { "type": "string", "minLength": 1 },
        "secretStoreRef": {
          "type": "object",
          "required": ["kind"],
          "properties": {
            "name": { "type": "string" },
            "kind": { "type": "string", "enum": ["SecretStore", "ClusterSecretStore"] }
          }
        },
        "targetName": { "type": "string" },
        "data": { "type": "array" },
        "dataFrom": { "type": "array" }
      }
    },
    "migrations": { "$ref": "#/definitions/job" },
    "bootstrapAdminJob": { "$ref": "#/definitions/job" },
    "seedConfigJob": { "$ref": "#/definitions/job" },
    "ingress": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": { "type": "array" },
        "tls": { "type": "array" }
      }
    },
    "autoscaling": {
      "type": "object",
      "required": ["enabled"],
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "metrics": { "type": "array", "minItems": 1 },
        "behavior": { "type": "object" }
      }
    },
    "rollout": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "strategy": { "type": "object" }
      }
    },
    "observability": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "env": { "$ref": "#/definitions/envList" },
        "podLabels": { "type": "object" },
        "podAnnotations": { "type": "object" },
        "sidecars": { "type": "array" },
        "volumes": { "type": "array" },
        "volumeMounts": { "type": "array" }
      }
    },
    "scheduling": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "resources": { "type": "object" },
        "nodeSelector": { "type": "object" },
        "affinity": { "type": "object" },
        "tolerations": { "type": "array" },
        "topologySpreadConstraints": { "type": "array" },
        "priorityClassName": { "type": "string" }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "string", "enum": ["auto"] }
          ]
        },
        "minAvailable": {
          "oneOf": [{ "type": "integer", "minimum": 0 }, { "type": "string" }]
        },
        "maxUnavailable": {
          "oneOf": [{ "type": "integer", "minimum": 0 }, { "type": "string" }]
        },
        "unhealthyPodEvictionPolicy": {
          "type": "string",
          "enum": ["AlwaysAllow", "IfHealthyBudget"]
        }
      }
    },
    "probes": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "gateway": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "liveness": { "$ref": "#/definitions/probe" },
            "readiness": { "$ref": "#/definitions/probe" }
          }
        },
        "adminUi": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "liveness": { "$ref": "#/definitions/probe" },
            "readiness": { "$ref": "#/definitions/probe" }
          }
        }
      }
    }
  },
  "definitions": {
    "image": {
      "type": "object",
      "required": ["repository"],
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "envList": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": true,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "value": { "type": "string" },
          "valueFrom": { "type": "object" }
        }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "size": { "type": "string", "minLength": 1 },
        "storageClass": { "type": "string" }
      }
    },
    "job": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "hook": { "type": "string", "minLength": 1 },
        "hookDeletePolicy": { "type": "string" },
        "annotations": { "type": "object" },
        "podAnnotations": { "type": "object" },
        "ttlSecondsAfterFinished": { "type": "integer", "minimum": 0 },
        "backoffLimit": { "type": "integer", "minimum": 0 },
        "resources": { "type": "object" }
      }
    },
    "probe": {
      "type": "object",
      "required": ["enabled"],
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "path": { "type": "string", "minLength": 1 },
        "initialDelaySeconds": { "type": "integer", "minimum": 0 },
        "periodSeconds": { "type": "integer", "minimum": 1 },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "failureThreshold": { "type": "integer", "minimum": 1 }
      },
      "allOf": [
        {
          "if": {
            "properties": { "enabled": { "const": true } },
            "required": ["enabled"]
          },
          "then": {
            "required": [
              "path",
              "initialDelaySeconds",
              "periodSeconds",
              "timeoutSeconds",
              "failureThreshold"
            ]
          }
        }
      ]
    }
  }
}
