{
  "name": "@oceans-llm/review-agent-action",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "rolldown -c && bun run scripts/normalize-dist.mjs",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check:dist": "bun run scripts/check-dist.mjs",
    "smoke:no-install": "bun run scripts/smoke-no-install.mjs"
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/github": "9.1.1"
  },
  "devDependencies": {
    "@types/node": "25.9.4",
    "bun-types": "1.3.14",
    "rolldown": "1.1.3",
    "typescript": "6.0.3"
  }
}
