{
  "name": "oceans-llm-docs",
  "private": true,
  "scripts": {
    "docs:check": "tsx ./scripts/docs-check.ts",
    "docs:dev": "vitepress dev . --host 0.0.0.0",
    "docs:build": "vitepress build .",
    "docs:preview": "vitepress preview . --host 0.0.0.0",
    "docs:deploy": "wrangler pages deploy .vitepress/dist --project-name oceans-llm-docs --branch main"
  },
  "devDependencies": {
    "wrangler": "4.79.0",
    "tsx": "^4.20.6",
    "vitepress": "1.6.4"
  }
}
